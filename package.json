{
  "name": "contextstream",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "deploy": "drizzle-kit migrate && next start",
    "lint": "next lint",
    "worker": "NODE_OPTIONS='--max-old-space-size=2048' tsx src/lib/jobs/worker.ts",
    "worker:clean": "NODE_OPTIONS='--max-old-space-size=2048' CLEAR_QUEUE_HISTORY_ON_STARTUP=true tsx src/lib/jobs/worker.ts",
    "jobs:clear": "tsx local_scripts/clear-jobs.ts",
    "jobs:clear-history": "tsx local_scripts/clear-queue-history.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:create": "drizzle-kit generate",
    "db:migrate:deploy": "drizzle-kit migrate",
    "db:reset": "drizzle-kit drop",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:global-docs": "tsx scripts/seed-global-docs.ts",
    "db:fix:stuck-sources": "tsx local_scripts/fix-stuck-sources.ts",
    "db:fix:source-usage": "tsx local_scripts/fix-source-usage-counts.ts",
    "user:upgrade": "tsx scripts/upgrade-user-plan.ts",
    "db:studio": "drizzle-kit studio",
    "generate-encryption-key": "tsx scripts/generate-encryption-key.ts",
    "prepare": "node -e \"try { require('husky').install() } catch (e) { if (e.code !== 'MODULE_NOT_FOUND') throw e }\"",
    "setup:hooks": "bash scripts/setup-hooks.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@types/bcryptjs": "^3.0.0",
    "@types/node-cron": "^3.0.11",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.5",
    "bull": "^4.16.5",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "file-type": "^21.3.2",
    "hash-wasm": "^4.12.0",
    "ioredis": "^5.10.0",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "next": "^16.1.7",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "openai": "^6.29.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0",
    "winston": "^3.19.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bull": "^4.10.4",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "eslint-config-next": "^16.1.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}